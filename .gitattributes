# Set default behaviour to normalize line endings in the index
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf
mvnw text eol=lf

# Java / Config files
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf

# Terraform
*.tf text eol=lf
*.tfvars text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# Binary files — never modify line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.jar binary
*.class binary
*.zip binary
